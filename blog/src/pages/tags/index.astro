---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const tils = await getCollection('til', ({ data }) => !data.draft);

const allTags = [...posts, ...tils].flatMap((item) => item.data.tags);
const tagCounts = allTags.reduce<Record<string, number>>((acc, tag) => {
  acc[tag] = (acc[tag] || 0) + 1;
  return acc;
}, {});

const sortedTags = Object.entries(tagCounts).sort(([, a], [, b]) => b - a);
---

<BaseLayout title="Tags — Sujeeth's Blog" description="Browse posts by tag">
  <div class="mb-10">
    <h1 class="text-3xl font-bold mb-2">Tags</h1>
    <p class="text-muted-foreground">Browse {sortedTags.length} topics across all posts.</p>
  </div>

  {sortedTags.length > 0 ? (
    <div class="flex flex-wrap gap-3">
      {sortedTags.map(([tag, count]) => (
        <a
          href={`/tags/${tag}`}
          class="group px-4 py-2.5 rounded-lg border border-border/50 bg-card hover:shadow-lg hover:border-highlight/30 transition-all duration-300 text-sm inline-flex items-center gap-2"
        >
          <span class="group-hover:text-highlight transition-colors">{tag}</span>
          <span class="text-xs text-muted-foreground bg-secondary px-1.5 py-0.5 rounded-md">{count}</span>
        </a>
      ))}
    </div>
  ) : (
    <p class="text-muted-foreground">No tags yet.</p>
  )}
</BaseLayout>
